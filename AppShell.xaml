<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="AppRpgEtec.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:AppRpgEtec"
    xmlns:viewArmas="clr-namespace:AppRpgEtec.Views.Armas"
     xmlns:viewPersonagem="clr-namespace:AppRpgEtec.Views.Personagens"
    Shell.FlyoutBehavior="Flyout"
    Title="AppRpgEtec">

    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate viewArmas:ListagemView}"
        Route="MainPage" />

    <ShellContent
    Title="Personagem"
    ContentTemplate="{DataTemplate viewPersonagem:ListagemView}"
    Route="App" />

</Shell>
